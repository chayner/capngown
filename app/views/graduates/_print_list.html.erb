
<div class="page-header">
  <div class="bulk-action-bar flex">
    <div>
      <%= link_to "Print All", show_bulk_path(buids: graduates.map(&:buid).join(',')), method: 'get', class: 'button' %>
    </div>
    <%= form_with url: print_path, local: true, method: :get do |form| %>
      <label>
        <input type="checkbox" name="printed" value="show" id="show-printed" <%= params[:printed] == 'show' ? "checked" : "" %>>
        <span class="checkable">Include Printed</span>
      </label>
      <%= form.hidden_field "form_submitted", value: "true" %>
    <% end %>
  </div>
</div>

<table class="primary">
  <thead>
    <tr>
      <td colspan="8" class="icon-legend">
        <span class="material-symbols-outlined">receipt_long</span>Pre-Ordered | 
        <span class="material-symbols-outlined">workspace_premium</span>Honors Cord |
        <span class="material-symbols-outlined">diagnosis</span>Brag Card |
        <span class="material-symbols-outlined">verified</span>Checked-In |
        <span class="material-symbols-outlined">Print</span>Printed
      </td>
    </tr>
    <tr>
      <th>Name</th>
      <th>Deg</th>
      <th>College</th>
      <th class="status-col"><span class="material-symbols-outlined">receipt_long</span></th>
      <th class="status-col"><span class="material-symbols-outlined">workspace_premium</span></th>
      <th class="status-col"><span class="material-symbols-outlined">diagnosis</span></th>
      <th class="status-col"><span class="material-symbols-outlined">verified</span></th>
      <th class="status-col"><span class="material-symbols-outlined">Print</span></th>
    <tr>
  </thead>
  <% graduates.each do |graduate| %>
    <tr>
      <td class="name-col" nowrap>
        <%= link_to "#{graduate.preferredlast.presence || graduate.lastname}, #{graduate.preferredfirst.presence || graduate.firstname}",
              graduate_path(buid: graduate.buid, lastname: params.fetch(:lastname, nil)) %>
      </td>
      <td nowrap>
        <%= graduate.degree1 %>
        <% if graduate.levelcode.start_with?("GR") %>
          <span class="material-symbols-outlined">school</span>
        <% end %>
      </td>
      <td nowrap>
        <span class="material-symbols-outlined"><%= CollegeCodeTranslator.icon(graduate.college1) %></span> <%= CollegeCodeTranslator.translate_short(graduate.college1) %>
      </td>
      <td class="status-col">
        <% if graduate.orderid.presence %>
          <span class="material-symbols-outlined">receipt_long</span>
        <% end %>
      </td>
      <td class="status-col">
        <% if graduate.honors.presence %>
          <span class="material-symbols-outlined">workspace_premium</span>
        <% end %>
      </td>
      <td class="status-col">
        <% if graduate.brags.any? %>
          <span class="material-symbols-outlined">diagnosis</span>        
        <% end %>
      </td>
      <td class="status-col">
        <% if graduate.checked_in? %>
          <span class="material-symbols-outlined">done</span>
        <% end %>
      </td>
      <td class="status-col">
        <% if graduate.printed? %>
          <span class="material-symbols-outlined">done</span>
        <% end %>
      </td>
    </tr>
  <% end %>
</table>
