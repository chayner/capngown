<h1>Pickup Stats</h1>

<h2>Students Already Printed</h2>
<ul>
  <li>Undergraduate: <%= @printed_undergrad %> out of <%= @total_undergrad %> (<%= @percent_printed_undergrad %>%)</li>
  <li>Master: <%= @printed_master %> out of <%= @total_master %> (<%= @percent_printed_master %>%)</li>
  <li>Doctorate: <%= @printed_doctorate %> out of <%= @total_doctorate %> (<%= @percent_printed_doctorate %>%)</li>
  <li>All Students: <%= @total_printed %> out of <%= @total_graduates %> (<%= @percent_printed %>%)</li>
</ul>

<h2>Handouts</h2>
<ul>
  <li>Alumni with Brag Cards Picked Up: <%= @graduates_with_brag_cards %> out of <%= @total_graduates_with_brag_cards %> (<%= @percent_brag_pickedup %>%)</li>
  <li>Alumni with WC Cords Picked Up: <%= @printed_with_cords %> out of <%= @total_with_cords %> (<%= @percent_printed_with_cords %>%)</li>
</ul>

<h2>Colleges</h2>
<p>
  <a href="#" id="expand-all">Expand All</a> |
  <a href="#" id="collapse-all">Collapse All</a>
</p>
<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Picked Up</th>
      <th>Total</th>
      <th>Percent</th>
    </tr>
  </thead>
  <tbody>
    <% @college_stats.each_with_index do |college, index| %>
      <tr class="college-row" data-college-index="<%= index %>" style="background-color: white;">
        <td>
          <% if college[:programs].present? %>
            <span class="toggle-icon" style="cursor: pointer; margin-right: 5px; font-size: 0.6em;">▶</span>
          <% end %>
          <%= college[:college_name] %>
        </td>
        <td><%= college[:printed] %></td>
        <td><%= college[:total] %></td>
        <td><%= college[:percent] %>%</td>
      </tr>
      <% college[:programs]&.each_with_index do |program, prog_index| %>
        <tr class="program-row program-<%= index %>" style="display: none; background-color: <%= prog_index.even? ? '#f3f3f3' : 'white' %>;">
          <td style="padding-left: 30px; font-style: italic;"><%= program[:major] %></td>
          <td><%= program[:printed] %></td>
          <td><%= program[:total] %></td>
          <td><%= program[:percent] %>%</td>
        </tr>
      <% end %>
    <% end %>
  </tbody>
</table>

<script>
  (function() {
    function initCollegeToggle() {
      // Toggle individual college
      document.querySelectorAll('.college-row').forEach(function(row) {
        row.style.cursor = 'pointer';
        row.onclick = function() {
          var index = this.dataset.collegeIndex;
          var programRows = document.querySelectorAll('.program-' + index);
          var icon = this.querySelector('.toggle-icon');
          
          programRows.forEach(function(programRow) {
            if (programRow.style.display === 'none') {
              programRow.style.display = 'table-row';
              if (icon) icon.textContent = '▼';
            } else {
              programRow.style.display = 'none';
              if (icon) icon.textContent = '▶';
            }
          });
        };
      });

      // Expand all
      var expandAll = document.getElementById('expand-all');
      if (expandAll) {
        expandAll.onclick = function(e) {
          e.preventDefault();
          document.querySelectorAll('.program-row').forEach(function(row) {
            row.style.display = 'table-row';
          });
          document.querySelectorAll('.toggle-icon').forEach(function(icon) {
            icon.textContent = '▼';
          });
        };
      }

      // Collapse all
      var collapseAll = document.getElementById('collapse-all');
      if (collapseAll) {
        collapseAll.onclick = function(e) {
          e.preventDefault();
          document.querySelectorAll('.program-row').forEach(function(row) {
            row.style.display = 'none';
          });
          document.querySelectorAll('.toggle-icon').forEach(function(icon) {
            icon.textContent = '▶';
          });
        };
      }
    }

    // Run immediately since script is at bottom of content
    initCollegeToggle();
    
    // Also listen for Turbo events in case of navigation
    document.addEventListener('turbo:load', initCollegeToggle);
  })();
</script>

<% if @printed_over_time.present? %>
  <h2>Printed Data Over Time</h2>
  <p>
    View by:
    <%= link_to "Hour", stats_graduates_path(interval: "hour") %> |
    <%= link_to "15 Minutes", stats_graduates_path(interval: "15min") %>
  </p>
  <table>
    <thead>
      <tr>
        <th>Time</th>
        <th>Total</th>
        <th>UG</th>
        <th>MA</th>
        <th>DR</th>
        <th>Brags</th>
      </tr>
    </thead>
    <tbody>
      <% @printed_over_time.each do |time, count| %>
        <% ug = @printed_undergrad_over_time[time] || 0 %>
        <% ma = @printed_master_over_time[time] || 0 %>
        <% dr = @printed_doctorate_over_time[time] || 0 %>
        <% brags = @brags_over_time[time] || 0 %>

        <% unless count == 0 && ug == 0 && ma == 0 && dr == 0 && brags == 0 %>
          <tr>
            <td>
              <% if params[:interval] == "15min" %>
                <%= time.in_time_zone("Central Time (US & Canada)").strftime("%m/%d %l:%M%P") %>
              <% else %>
                <%= time.in_time_zone("Central Time (US & Canada)").strftime("%m/%d %l%P").strip %>
              <% end %>
            </td>
            <td><%= count %></td>
            <td><%= ug %></td>
            <td><%= ma %></td>
            <td><%= dr %></td>
            <td><%= brags %></td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
<% end %>