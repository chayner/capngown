<div  id="to-print">
  <%= render partial: 'print_list', locals: { graduates: @graduates } %>
</div>

<script>
  if (window.pollIntervalId) {
    clearInterval(window.pollIntervalId);
  }

  document.addEventListener("turbo:load", function () {
  
    function updatePrintList() {
      const toggle = document.getElementById('show-printed');
      if (!toggle) return;

      let show_print = toggle.checked ? 'show' : 'hide';

      fetch(`/get_print?printed=${show_print}`)
        .then(response => response.text())
        .then(html => {
          const container = document.getElementById('to-print');
          if (container) {
            container.innerHTML = html;
            const hasResults = container.querySelectorAll('.graduate-row').length > 0;
            document.body.style.backgroundColor = hasResults ? '#E1EBCA' : '';
          }
        })
        .catch(error => console.error(error));
    }
    
    const toggle = document.getElementById('show-printed');
    if (toggle) {
      toggle.addEventListener('click', updatePrintList);
      updatePrintList();
      window.pollIntervalId = setInterval(updatePrintList, 5000);
    }

  });

  document.addEventListener("turbo:before-cache", function () {
    if (window.pollIntervalId) {
      clearInterval(window.pollIntervalId);
      window.pollIntervalId = null;
    }
  });
</script>
