<div  id="to-print" data-print-page="true">
  <%= render partial: 'print_list', locals: { graduates: @graduates } %>
</div>

<script>
  if (window.pollIntervalId) {
    clearInterval(window.pollIntervalId);
    window.pollIntervalId = null;
  }

  document.addEventListener("turbo:load", function () {
    const container = document.getElementById('to-print');
    // Only run on the print-list page. Without this guard, Turbo Drive
    // would replay the green-background side effect on other pages
    // because the inline body style persists across navigations.
    if (!container || !container.dataset.printPage) {
      document.body.classList.remove('print-page-has-results');
      return;
    }

    document.body.classList.add('on-print-page');

    // Pause polling while the user is interacting with the list (hover or
    // active mousedown). Without this, a 5s innerHTML swap can land between
    // mousedown and mouseup, swallowing the click on "Print All" or a name.
    let userInteracting = false;
    let interactionResetTimer = null;

    function markInteracting() {
      userInteracting = true;
      if (interactionResetTimer) clearTimeout(interactionResetTimer);
      // Safety net: if mouseleave/mouseup never fire (e.g. user clicked a
      // link and Turbo navigated mid-click), force the flag back to false
      // so polling resumes when they return to this page.
      interactionResetTimer = setTimeout(() => { userInteracting = false; }, 2000);
    }
    function clearInteracting() {
      userInteracting = false;
      if (interactionResetTimer) {
        clearTimeout(interactionResetTimer);
        interactionResetTimer = null;
      }
    }

    container.addEventListener('mouseenter', markInteracting);
    container.addEventListener('mouseleave', clearInteracting);
    container.addEventListener('mousedown',  markInteracting);

    function updatePrintList() {
      if (userInteracting) return;

      const toggle = document.getElementById('show-printed');
      if (!toggle) return;

      let show_print = toggle.checked ? 'show' : 'hide';

      fetch(`/get_print?printed=${show_print}`)
        .then(response => response.text())
        .then(html => {
          if (userInteracting) return;
          const live = document.getElementById('to-print');
          if (!live) return;
          // Only replace when content actually changed — avoids destroying
          // links/buttons under the user's cursor on every poll.
          if (live.innerHTML !== html) {
            live.innerHTML = html;
          }
          const hasResults = live.querySelectorAll('.graduate-row').length > 0;
          document.body.classList.toggle('print-page-has-results', hasResults);
        })
        .catch(error => console.error(error));
    }

    const toggle = document.getElementById('show-printed');
    if (toggle) {
      toggle.addEventListener('click', updatePrintList);
      updatePrintList();
      window.pollIntervalId = setInterval(updatePrintList, 5000);
    }

  });

  // Clean up when leaving the print page so the green background doesn't
  // bleed onto the bulk-print or graduate detail pages.
  document.addEventListener("turbo:before-cache", function () {
    if (window.pollIntervalId) {
      clearInterval(window.pollIntervalId);
      window.pollIntervalId = null;
    }
    document.body.classList.remove('on-print-page', 'print-page-has-results');
  });

  document.addEventListener("turbo:before-visit", function () {
    document.body.classList.remove('on-print-page', 'print-page-has-results');
  });
</script>
