<div  id="to-print">
  <%= render partial: 'print_list', locals: { graduates: @graduates } %>
</div>

<script>
  if (window.pollIntervalId) {
    clearInterval(window.pollIntervalId);
  }

  document.addEventListener("turbo:load", function () {
    const container = document.getElementById('to-print');
    if (!container) return;

    // Pause polling while the user is interacting with the list (hover or
    // active mousedown). Without this, a 5s innerHTML swap can land between
    // mousedown and mouseup, swallowing the click on "Print All" or a name.
    let userInteracting = false;
    container.addEventListener('mouseenter', () => { userInteracting = true; });
    container.addEventListener('mouseleave', () => { userInteracting = false; });
    container.addEventListener('mousedown',  () => { userInteracting = true; });
    // Don't reset on mouseup — the navigation begins immediately after.

    function updatePrintList() {
      if (userInteracting) return;

      const toggle = document.getElementById('show-printed');
      if (!toggle) return;

      let show_print = toggle.checked ? 'show' : 'hide';

      fetch(`/get_print?printed=${show_print}`)
        .then(response => response.text())
        .then(html => {
          if (userInteracting) return; // user started interacting mid-fetch
          if (!container) return;
          // Only replace when content actually changed — avoids destroying
          // links/buttons under the user's cursor on every poll.
          if (container.innerHTML !== html) {
            container.innerHTML = html;
          }
          const hasResults = container.querySelectorAll('.graduate-row').length > 0;
          document.body.style.backgroundColor = hasResults ? '#E1EBCA' : '';
        })
        .catch(error => console.error(error));
    }

    const toggle = document.getElementById('show-printed');
    if (toggle) {
      toggle.addEventListener('click', updatePrintList);
      updatePrintList();
      window.pollIntervalId = setInterval(updatePrintList, 5000);
    }

  });

  document.addEventListener("turbo:before-cache", function () {
    if (window.pollIntervalId) {
      clearInterval(window.pollIntervalId);
      window.pollIntervalId = null;
    }
  });
</script>
